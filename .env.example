# Copy this file to .env and fill in real values locally.
# In production, set these in the Vercel dashboard (Project → Settings → Environment Variables).
# NEVER commit a filled-in .env — it is gitignored on purpose.

# --- Kinde auth ---
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=
KINDE_SITE_URL=
KINDE_POST_LOGOUT_REDIRECT_URL=
KINDE_POST_LOGIN_REDIRECT_URL=

# --- Database (Postgres) ---
DATABASE_URL=

# --- UploadThing ---
UPLOADTHING_TOKEN=
UPLOADTHING_SECRET_KEY=

# --- App ---
NEXT_PUBLIC_BASE_URL=

# --- SMTP (invite emails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=
